{
  "manifest_version": 3,
  "name": "PromptBolt",
  "version": "0.0.0",
  "description": "Save prompts and insert them on any page.",
  "action": {
    "default_popup": "index.html",
    "default_title": "PromptBolt"
  },
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
